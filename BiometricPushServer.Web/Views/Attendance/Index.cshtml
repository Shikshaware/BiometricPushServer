@{
    Layout = "_Layout";
    ViewData["Title"] = "Attendance";
}
@model BiometricPushServer.Common.DTOs.PagedResult<BiometricPushServer.Common.DTOs.AttendanceLogDto>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-clock-history"></i> Attendance Logs</h3>
    <a asp-action="Today" class="btn btn-primary"><i class="bi bi-calendar-day"></i> Today's Logs</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr><th>Time</th><th>User</th><th>Device SN</th><th>State</th><th>Method</th><th>Dup?</th></tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Items)
                {
                    <tr class="@(log.IsDuplicate ? "table-warning" : "")">
                        <td>@log.PunchTime.ToString("dd-MMM-yyyy HH:mm:ss")</td>
                        <td>@log.UserCode @(string.IsNullOrEmpty(log.UserName) ? "" : $"({log.UserName})")</td>
                        <td><code>@log.DeviceSN</code></td>
                        <td>@log.AttendanceState</td>
                        <td>@log.VerifyMode</td>
                        <td>@(log.IsDuplicate ? "⚠" : "")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <span>Page @Model.PageNumber of @Model.TotalPages — @Model.TotalCount total records</span>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                @if (Model.PageNumber > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-pageNumber="@(Model.PageNumber - 1)"
                           asp-route-pageSize="@Model.PageSize">Previous</a>
                    </li>
                }
                @for (int p = Math.Max(1, Model.PageNumber - 2); p <= Math.Min(Model.TotalPages, Model.PageNumber + 2); p++)
                {
                    <li class="page-item @(p == Model.PageNumber ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-pageNumber="@p"
                           asp-route-pageSize="@Model.PageSize">@p</a>
                    </li>
                }
                @if (Model.PageNumber < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-pageNumber="@(Model.PageNumber + 1)"
                           asp-route-pageSize="@Model.PageSize">Next</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>
