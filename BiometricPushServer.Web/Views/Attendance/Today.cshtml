@{
    Layout = "_Layout";
    ViewData["Title"] = "Today's Attendance";
}
@model IEnumerable<BiometricPushServer.Common.DTOs.AttendanceLogDto>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-calendar-day"></i> Today's Attendance</h3>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> All Logs</a>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@DateTime.Today.ToString("dddd, dd MMMM yyyy")</span>
        <span class="badge bg-info">@Model.Count() punch(es)</span>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Time</th>
                    <th>User</th>
                    <th>Device SN</th>
                    <th>State</th>
                    <th>Method</th>
                    <th>Duplicate?</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr class="@(log.IsDuplicate ? "table-warning" : "")">
                        <td>@log.PunchTime.ToString("HH:mm:ss")</td>
                        <td>@log.UserCode @(string.IsNullOrEmpty(log.UserName) ? "" : $"({log.UserName})")</td>
                        <td><code>@log.DeviceSN</code></td>
                        <td>@log.AttendanceState</td>
                        <td>@log.VerifyMode</td>
                        <td>@(log.IsDuplicate ? "⚠ Yes" : "")</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No attendance records for today yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
