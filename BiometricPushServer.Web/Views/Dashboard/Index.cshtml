@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";
    var isProviderView = (bool?)ViewBag.IsProviderView ?? false;
    var selectedClientId = (int?)ViewBag.SelectedClientId;
    var clientTimeZoneId = (string?)ViewBag.ClientTimeZoneId ?? "UTC";
    var clients = (IEnumerable<BiometricPushServer.Common.DTOs.ClientDashboardOptionDto>?)ViewBag.Clients
        ?? Enumerable.Empty<BiometricPushServer.Common.DTOs.ClientDashboardOptionDto>();
}
@model BiometricPushServer.Common.DTOs.DashboardStatsDto

<h3 class="mb-4"><i class="bi bi-speedometer2"></i> Live Dashboard</h3>

@if (isProviderView)
{
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-2 align-items-end">
                <div class="col-md-6">
                    <label class="form-label">Client</label>
                    <select class="form-select" name="clientId" required>
                        <option value="">Select client...</option>
                        @foreach (var client in clients)
                        {
                            @if (selectedClientId == client.ClientId)
                            {
                                <option value="@client.ClientId" selected>
                                    @client.DisplayName (@client.ClientId) — @client.TimeZoneId
                                </option>
                            }
                            else
                            {
                                <option value="@client.ClientId">
                                    @client.DisplayName (@client.ClientId) — @client.TimeZoneId
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-arrow-right-circle"></i> Open Dashboard
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">
            <i class="bi bi-person-plus"></i> Create Owner Invite
        </div>
        <div class="card-body">
            <form id="ownerInviteForm" class="row g-2 align-items-end">
                @Html.AntiForgeryToken()
                <div class="col-md-3">
                    <label class="form-label">Client ID</label>
                    <input id="inviteClientId" name="clientId" type="number" class="form-control" min="1" value="@(selectedClientId?.ToString() ?? string.Empty)" aria-describedby="inviteClientIdHelp" @(selectedClientId.HasValue ? "readonly=\"readonly\"" : "") required />
                    <small id="inviteClientIdHelp" class="text-muted">When a client is selected from provider dashboard, Client ID is locked here.</small>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Owner Username</label>
                    <input id="inviteUsername" name="username" type="text" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Time Zone ID</label>
                    <input id="inviteTimeZoneId" name="timeZoneId" type="text" class="form-control" value="@clientTimeZoneId" placeholder="UTC" aria-describedby="inviteTimeZoneHelp" />
                    <small id="inviteTimeZoneHelp" class="text-muted">Use a valid IANA/OS timezone identifier.</small>
                </div>
                <div class="col-md-3">
                    <button id="createInviteBtn" type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-envelope-paper"></i> Generate Invite Token
                    </button>
                </div>
            </form>
            <div id="ownerInviteResult" class="small mt-3 text-muted" role="status" aria-live="polite">Complete the form and generate an owner invite token.</div>
            <div id="ownerInviteActions" class="mt-2 d-none">
                <button id="toggleInviteTokenBtn" type="button" class="btn btn-sm btn-outline-secondary me-2">Show Token</button>
                <button id="copyInviteTokenBtn" type="button" class="btn btn-sm btn-outline-primary">Copy Token</button>
            </div>
            <div id="copyInviteStatus" class="visually-hidden" aria-live="polite"></div>
            <div class="small text-warning mt-1">Keep invite tokens secure and share only with the intended owner.</div>
        </div>
    </div>

    @if (!selectedClientId.HasValue)
    {
        <div class="alert alert-info">Select a client to view the client-specific dashboard and attendance reports.</div>
    }
}

@if (!isProviderView || selectedClientId.HasValue)
{
    <div class="alert alert-secondary">
        <strong>Client Timezone:</strong> @clientTimeZoneId
    </div>

    <!-- Stat cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-2">
            <div class="card card-stat border-primary text-center p-3">
                <div class="fs-2 fw-bold text-primary">@Model.TotalDevices</div>
                <small>Total Devices</small>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card card-stat border-success text-center p-3">
                <div class="fs-2 fw-bold text-success">@Model.OnlineDevices</div>
                <small>Online</small>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card card-stat border-danger text-center p-3">
                <div class="fs-2 fw-bold text-danger">@Model.OfflineDevices</div>
                <small>Offline</small>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card card-stat border-info text-center p-3">
                <div class="fs-2 fw-bold text-info" id="todayCount">@Model.TodayAttendance</div>
                <small>Today's Punches</small>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card card-stat border-warning text-center p-3">
                <div class="fs-2 fw-bold text-warning">@Model.TotalUsers</div>
                <small>Users</small>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card card-stat border-secondary text-center p-3">
                <div class="fs-2 fw-bold text-secondary">@Model.PendingCommands</div>
                <small>Pending Cmds</small>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-table"></i> Attendance Report</span>
            <span class="small text-muted">Daily / Weekly / Monthly</span>
        </div>
        <div class="card-body">
            <div class="row g-2 mb-3">
                <div class="col-md-3">
                    <label class="form-label">Period</label>
                    <select id="reportPeriod" class="form-select">
                        <option value="daily">Daily</option>
                        <option value="weekly">Weekly</option>
                        <option value="monthly">Monthly</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Reference Date</label>
                    <input id="reportDate" type="date" class="form-control" value="@DateTime.UtcNow.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-6 d-flex align-items-end gap-2">
                    <button id="loadReportBtn" type="button" class="btn btn-primary">
                        <i class="bi bi-search"></i> View
                    </button>
                    <button id="downloadReportBtn" type="button" class="btn btn-success">
                        <i class="bi bi-file-earmark-excel"></i> Download Excel
                    </button>
                </div>
            </div>
            <div id="reportMeta" class="small text-muted mb-2"></div>
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Date</th>
                            <th>User</th>
                            <th>First In</th>
                            <th>Last Out</th>
                            <th>Punch Count</th>
                        </tr>
                    </thead>
                    <tbody id="reportBody">
                        <tr><td colspan="5" class="text-muted">No report loaded.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Live feed -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-broadcast"></i> Live Attendance Feed</span>
            <span id="hubStatus" class="badge bg-warning">Connecting...</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0" id="attTable">
                <thead class="table-dark">
                    <tr>
                        <th>Time</th><th>User</th><th>Device</th>
                        <th>State</th><th>Method</th><th>Duplicate</th>
                    </tr>
                </thead>
                <tbody id="attBody">
                    @foreach (var log in Model.RecentPunches)
                    {
                        <tr>
                            <td>@log.PunchTime.ToString("HH:mm:ss")</td>
                            <td>@log.UserCode @(string.IsNullOrEmpty(log.UserName) ? "" : $"({log.UserName})")</td>
                            <td>@log.DeviceSN</td>
                            <td>@log.AttendanceState</td>
                            <td>@log.VerifyMode</td>
                            <td>@(log.IsDuplicate ? "⚠" : "")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script>
    const selectedClientId = '@(selectedClientId?.ToString() ?? string.Empty)';

    async function loadReport() {
        if (!selectedClientId) return;
        const period = document.getElementById("reportPeriod").value;
        const referenceDate = document.getElementById("reportDate").value;
        const response = await fetch(`/api/attendance/report?clientId=${encodeURIComponent(selectedClientId)}&period=${encodeURIComponent(period)}&referenceDate=${encodeURIComponent(referenceDate)}`);
        const payload = await response.json();
        if (!payload.success) {
            document.getElementById("reportBody").innerHTML = `<tr><td colspan="5" class="text-danger">${payload.message || 'Failed to load report'}</td></tr>`;
            return;
        }

        const report = payload.data;
        document.getElementById("reportMeta").textContent = `Range: ${report.rangeStart} to ${report.rangeEnd} (${report.timeZoneId})`;
        if (!report.rows || report.rows.length === 0) {
            document.getElementById("reportBody").innerHTML = '<tr><td colspan="5" class="text-muted">No records found for this period.</td></tr>';
            return;
        }

        document.getElementById("reportBody").innerHTML = report.rows.map(r =>
            `<tr>
                <td>${r.date}</td>
                <td>${r.userCode} ${r.userName ? '(' + r.userName + ')' : ''}</td>
                <td>${r.firstIn}</td>
                <td>${r.lastOut}</td>
                <td>${r.punchCount}</td>
            </tr>`
        ).join('');
    }

    const loadReportBtn = document.getElementById("loadReportBtn");
    if (loadReportBtn) {
        loadReportBtn.addEventListener("click", loadReport);
        loadReport();
    }

    const downloadReportBtn = document.getElementById("downloadReportBtn");
    if (downloadReportBtn) {
        downloadReportBtn.addEventListener("click", function () {
            const period = document.getElementById("reportPeriod").value;
            const referenceDate = document.getElementById("reportDate").value;
            window.location.href = `/api/attendance/report/export?clientId=${encodeURIComponent(selectedClientId)}&period=${encodeURIComponent(period)}&referenceDate=${encodeURIComponent(referenceDate)}`;
        });
    }

    const ownerInviteForm = document.getElementById("ownerInviteForm");
    let latestInviteToken = "";
    let latestInviteExpiresOn = "";
    let isInviteTokenVisible = false;

    function maskToken(token) {
        if (!token) return "";
        return "Token hidden for security";
    }

    function formatUtcExpiry(value) {
        if (!value) return "";
        const parsed = new Date(value);
        if (Number.isNaN(parsed.getTime())) return "Invalid date";
        return parsed.toISOString();
    }

    function renderInviteResult(resultElement) {
        const tokenToShow = isInviteTokenVisible ? latestInviteToken : maskToken(latestInviteToken);
        resultElement.textContent = `Invite token: ${tokenToShow} | Expires On (UTC): ${formatUtcExpiry(latestInviteExpiresOn)}`;
    }

    if (ownerInviteForm) {
        const result = document.getElementById("ownerInviteResult");
        const actions = document.getElementById("ownerInviteActions");
        const toggleBtn = document.getElementById("toggleInviteTokenBtn");
        const copyBtn = document.getElementById("copyInviteTokenBtn");
        const copyStatus = document.getElementById("copyInviteStatus");

        if (toggleBtn) {
            toggleBtn.addEventListener("click", function () {
                if (!latestInviteToken) return;
                isInviteTokenVisible = !isInviteTokenVisible;
                toggleBtn.textContent = isInviteTokenVisible ? "Hide Token" : "Show Token";
                renderInviteResult(result);
            });
        }

        if (copyBtn) {
            copyBtn.addEventListener("click", async function () {
                if (!latestInviteToken) return;
                if (!navigator.clipboard) {
                    copyBtn.textContent = "Copy not supported";
                    if (copyStatus) copyStatus.textContent = "Copy is not supported in this browser.";
                    setTimeout(() => copyBtn.textContent = "Copy Token", 1500);
                    return;
                }
                try {
                    await navigator.clipboard.writeText(latestInviteToken);
                    copyBtn.textContent = "Copied";
                    if (copyStatus) copyStatus.textContent = "Token copied to clipboard.";
                    setTimeout(() => copyBtn.textContent = "Copy Token", 1500);
                } catch {
                    copyBtn.textContent = "Copy failed";
                    if (copyStatus) copyStatus.textContent = "Copy failed.";
                    setTimeout(() => copyBtn.textContent = "Copy Token", 1500);
                }
            });
        }

        ownerInviteForm.addEventListener("submit", async function (event) {
            event.preventDefault();
            const createBtn = document.getElementById("createInviteBtn");
            const tokenInput = ownerInviteForm.querySelector('input[name="__RequestVerificationToken"]');
            const clientId = document.getElementById("inviteClientId").value;
            const username = document.getElementById("inviteUsername").value;
            const timeZoneId = document.getElementById("inviteTimeZoneId").value;

            if (!clientId) {
                result.className = "small mt-3 text-danger";
                result.textContent = "Client ID is required.";
                return;
            }

            createBtn.disabled = true;
            result.className = "small mt-3 text-muted";
            result.textContent = "Generating invite token...";
            if (actions) actions.classList.add("d-none");
            if (toggleBtn) toggleBtn.textContent = "Show Token";
            latestInviteToken = "";
            latestInviteExpiresOn = "";
            isInviteTokenVisible = false;

            try {
                const response = await fetch("/api/auth/create-owner-invite", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": tokenInput?.value || ""
                    },
                    body: JSON.stringify({
                        clientId: Number(clientId),
                        username: username,
                        timeZoneId: timeZoneId
                    })
                });

                const payload = await response.json();
                if (!response.ok || !payload.success) {
                    result.className = "small mt-3 text-danger";
                    if (response.status === 400) {
                        result.textContent = payload.message || "Invalid invite data. Please check all fields.";
                    } else if (response.status === 401 || response.status === 403) {
                        result.textContent = "You are not authorized to create owner invites.";
                    } else {
                        result.textContent = payload.message || "Failed to create owner invite due to a server error.";
                    }
                    return;
                }

                const data = payload.data || {};
                latestInviteToken = data.token || "";
                latestInviteExpiresOn = data.expiresOn || "";
                result.className = "small mt-3 text-success";
                renderInviteResult(result);
                if (actions && latestInviteToken) actions.classList.remove("d-none");
            } catch (error) {
                console.error("Owner invite creation failed", error?.message || "Unknown error");
                result.className = "small mt-3 text-danger";
                if (error instanceof TypeError) {
                    result.textContent = "Network error while creating invite. Please check your connection and try again.";
                } else {
                    result.textContent = `Unexpected error while creating invite: ${error?.message || "Unknown error"}`;
                }
            } finally {
                createBtn.disabled = false;
            }
        });
    }

    if (selectedClientId) {
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/attendance")
            .withAutomaticReconnect()
            .build();

        connection.on("AttendanceUpdated", function (logs) {
            const tbody = document.getElementById("attBody");
            tbody.innerHTML = "";
            let count = 0;
            logs.slice(0, 20).forEach(function (log) {
                const row = `<tr>
                    <td>${new Date(log.punchTime).toLocaleTimeString()}</td>
                    <td>${log.userCode} ${log.userName ? '(' + log.userName + ')' : ''}</td>
                    <td>${log.deviceSN}</td>
                    <td>${log.attendanceState}</td>
                    <td>${log.verifyMode}</td>
                    <td>${log.isDuplicate ? '⚠' : ''}</td>
                </tr>`;
                tbody.insertAdjacentHTML('afterbegin', row);
                count++;
            });
            document.getElementById("todayCount").textContent = logs.length;
        });

        connection.on("Connected", function () {
            document.getElementById("hubStatus").textContent = "Live";
            document.getElementById("hubStatus").className = "badge bg-success";
        });

        connection.start().catch(function (err) {
            console.error(err.toString());
            document.getElementById("hubStatus").textContent = "Offline";
            document.getElementById("hubStatus").className = "badge bg-danger";
        });
    }
</script>
}
