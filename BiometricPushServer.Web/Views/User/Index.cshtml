@{
    Layout = "_Layout";
    ViewData["Title"] = "Users";
}
@model BiometricPushServer.Common.DTOs.PagedResult<BiometricPushServer.Common.DTOs.UserDto>

<h3 class="mb-3"><i class="bi bi-people"></i> Users</h3>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr><th>Code</th><th>Name</th><th>Card</th><th>Privilege</th><th>Enabled</th></tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Items)
                {
                    <tr>
                        <td>@u.UserCode</td>
                        <td>@u.Name</td>
                        <td>@u.CardNumber</td>
                        <td>@(u.Privilege == 14 ? "Admin" : "User")</td>
                        <td>@(u.IsEnabled ? "✔" : "✘")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <span>Page @Model.PageNumber of @Model.TotalPages — @Model.TotalCount total users</span>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                @if (Model.PageNumber > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-pageNumber="@(Model.PageNumber - 1)"
                           asp-route-pageSize="@Model.PageSize">Previous</a>
                    </li>
                }
                @for (int p = Math.Max(1, Model.PageNumber - 2); p <= Math.Min(Model.TotalPages, Model.PageNumber + 2); p++)
                {
                    <li class="page-item @(p == Model.PageNumber ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-pageNumber="@p"
                           asp-route-pageSize="@Model.PageSize">@p</a>
                    </li>
                }
                @if (Model.PageNumber < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-pageNumber="@(Model.PageNumber + 1)"
                           asp-route-pageSize="@Model.PageSize">Next</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>
