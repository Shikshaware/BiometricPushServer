<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BiometricPushServer</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        .sidebar { min-height: 100vh; background-color: #1a1a2e; }
        .sidebar .nav-link { color: #adb5bd; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background-color: rgba(255,255,255,.1); }
        .sidebar .brand { color: #fff; font-weight: bold; font-size: 1.2rem; }
        .status-online  { color: #28a745; }
        .status-offline { color: #dc3545; }
        .card-stat { border-left: 4px solid; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 d-none d-md-block sidebar py-3">
                <div class="brand mb-4 px-3"><i class="bi bi-fingerprint"></i> BioServer</div>
                <ul class="nav flex-column">
                    <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Device" asp-action="Index"><i class="bi bi-cpu"></i> Devices</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Attendance" asp-action="Index"><i class="bi bi-clock-history"></i> Attendance</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="User" asp-action="Index"><i class="bi bi-people"></i> Users</a></li>
                    <li class="nav-item mt-3">
                        <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="nav-link btn btn-link p-0"><i class="bi bi-box-arrow-right"></i> Logout</button>
                        </form>
                    </li>
                </ul>
            </nav>
            <main class="col-md-10 ms-sm-auto px-4 py-3">
                @RenderBody()
            </main>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
